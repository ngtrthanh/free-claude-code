# ═══════════════════════════════════════════════════════════════════════════
# Cortex Smart Routing — Example Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Cortex automatically routes requests to the right provider based on complexity.
# Configure tiers below, then set MODEL="cortex/auto" to enable.

# ── Provider API Keys (same as main .env) ──────────────────────────────────────
NVIDIA_NIM_API_KEY="your-nvidia-key"
OPENROUTER_API_KEY="your-openrouter-key"
DEEPSEEK_API_KEY=""

# ── Local Providers (no API key needed) ────────────────────────────────────────
LM_STUDIO_BASE_URL="http://192.168.11.13:8000"
LLAMACPP_BASE_URL="http://192.168.11.10:8080/v1"
OLLAMA_BASE_URL="http://192.168.11.10:11434"

# ── Enable Cortex ──────────────────────────────────────────────────────────────
# Set MODEL to "cortex/auto" to enable smart routing
MODEL="cortex/auto"

# Or use cortex for specific tiers:
# MODEL_OPUS="cortex/auto"
# MODEL_SONNET="nvidia_nim/deepseek-ai/deepseek-v4-pro"
# MODEL_HAIKU="cortex/auto"

# ── Tier Definitions ───────────────────────────────────────────────────────────
# Each tier is a comma-separated list of provider/model strings.
# Cortex tries them in order, falling back on error.

# LOCAL tier — free, on-device (score 0-24)
CORTEX_LOCAL_MODELS="lmstudio/gemma-4-E4B-it-MLX-8bit,ollama/llama3.2"

# REMOTE tier — cheap cloud (score 25-54)
CORTEX_REMOTE_MODELS="open_router/meta-llama/llama-3.1-8b-instruct:free,deepseek/deepseek-chat"

# SMART tier — capable cloud (score 55-84)
CORTEX_SMART_MODELS="nvidia_nim/deepseek-ai/deepseek-v4-pro,open_router/anthropic/claude-sonnet-4"

# NATIVE tier — native Anthropic (score 85-100)
CORTEX_NATIVE_MODELS="open_router/anthropic/claude-opus-4"

# ── Score Thresholds ───────────────────────────────────────────────────────────
# Minimum score to route to each tier (0-100)
CORTEX_THRESHOLD_LOCAL=0
CORTEX_THRESHOLD_REMOTE=25
CORTEX_THRESHOLD_SMART=55
CORTEX_THRESHOLD_NATIVE=85

# ── Fallback Behavior ──────────────────────────────────────────────────────────
# On error, try smarter tiers (local → remote → smart → native)
CORTEX_FALLBACK_ASCENDING=true

# On error, also try cheaper tiers after ascending exhausted
CORTEX_FALLBACK_DESCENDING=true

# ── Other Settings (same as main .env) ─────────────────────────────────────────
ENABLE_MODEL_THINKING=true
PROVIDER_RATE_LIMIT=1
PROVIDER_RATE_WINDOW=3
PROVIDER_MAX_CONCURRENCY=5
HTTP_READ_TIMEOUT=120
HTTP_WRITE_TIMEOUT=10
HTTP_CONNECT_TIMEOUT=10
ANTHROPIC_AUTH_TOKEN=
MESSAGING_PLATFORM="none"
ENABLE_NETWORK_PROBE_MOCK=true
ENABLE_TITLE_GENERATION_SKIP=true
ENABLE_SUGGESTION_MODE_SKIP=true
ENABLE_FILEPATH_EXTRACTION_MOCK=true
ENABLE_WEB_SERVER_TOOLS=false
LOG_API_ERROR_TRACEBACKS=false
